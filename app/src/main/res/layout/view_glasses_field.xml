<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/glasses_field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <!-- Top line: brightness + signal bars when connected, link status when not. -->
    <TextView
        android:id="@+id/gf_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#B0B0B0"
        android:textStyle="bold"
        android:textSize="13sp" />

    <!-- Main line: glasses battery % (coloured by level), or the tap hint when disconnected. -->
    <TextView
        android:id="@+id/gf_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="26sp" />
</LinearLayout>
